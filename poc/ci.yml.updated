name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  GO_VERSION: "1.25"

jobs:
  # ── Go Backend ──────────────────────────────────────
  go-test:
    name: Go Test & Lint
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: poc
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: ${{ env.GO_VERSION }}
      - name: Build
        run: go build ./...
      - name: Vet
        run: go vet ./...
      - name: Test
        run: go test -race -v ./...

  # ── Flutter App ─────────────────────────────────────
  flutter-analyze:
    name: Flutter Analyze
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: app
    steps:
      - uses: actions/checkout@v4
      - uses: subosito/flutter-action@v2
        with:
          flutter-version: "3.12"
      - name: Get dependencies
        run: flutter pub get
      - name: Analyze
        run: flutter analyze

  # ── Agent Build (Windows) ───────────────────────────
  agent-build-windows:
    name: Agent Build (Windows)
    needs: [go-test]
    runs-on: windows-latest
    defaults:
      run:
        working-directory: poc
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: ${{ env.GO_VERSION }}
      - name: Build
        run: go build -ldflags="-s -w" -o ../release/crosslink-agent.exe ./ollama-agent/
      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: crosslink-agent-windows
          path: release/crosslink-agent.exe

  # ── Agent Build (Linux) ─────────────────────────────
  agent-build-linux:
    name: Agent Build (Linux)
    needs: [go-test]
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: poc
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: ${{ env.GO_VERSION }}
      - name: Build
        run: go build -ldflags="-s -w" -o ../release/crosslink-agent-linux ./ollama-agent/
      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: crosslink-agent-linux
          path: release/crosslink-agent-linux
